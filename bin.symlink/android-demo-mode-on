#!/usr/bin/env bash
# Enable Android demo mode and set a perfect status bar for screenshots.
# Requires a device/emulator connected via adb.

set -euo pipefail

adb shell settings put global sysui_demo_allowed 1
adb shell am broadcast -a com.android.systemui.demo -e command enter

# Clock set to 9:41
adb shell am broadcast -a com.android.systemui.demo -e command clock -e hhmm 0941

# Full mobile signal, LTE
# adb shell am broadcast -a com.android.systemui.demo -e command network -e mobile show -e level 4 -e datatype lte
adb shell am broadcast -a com.android.systemui.demo -e command network -e mobile hide

# Full wifi signal
adb shell am broadcast -a com.android.systemui.demo -e command network -e wifi show -e level 4 -e fully true

# Full battery, not charging
adb shell am broadcast -a com.android.systemui.demo -e command battery -e level 100 -e plugged false

# Hide notification icons
adb shell am broadcast -a com.android.systemui.demo -e command notifications -e visible false

echo "Android demo mode enabled with perfect status bar."
