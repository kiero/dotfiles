#!/usr/bin/env bash
#
# Run all dotfiles installers.

set -e

cd "$(dirname $0)"/..

if [[ "$(uname)" == "Darwin" ]]; then
  # Install Homebrew
  ./homebrew/install_homebrew.sh

  # Run Homebrew through the Brewfile (skipped in CI — casks and GUI apps not supported)
  if [ -z "$CI" ]; then
    echo "› brew bundle"
    brew bundle --file="./homebrew/Brewfile"
    brew bundle --file="./homebrew/Brewfile.cask"
  else
    echo "› Skipping brew bundle in CI environment"
  fi

  # Set macOS defaults (skipped in CI — no GUI, sudo restrictions)
  if [ -z "$CI" ]; then
    echo "› Setting macOS defaults..."
    ./macos/set_defaults.sh
  else
    echo "› Skipping macOS defaults in CI environment"
  fi
fi

# find the installers and run them iteratively
echo "› Installing installers..."
while IFS= read -r installer; do
  echo "› Running ${installer}..."
  bash "${installer}"
done < <(find . -name install.sh)

echo "› Changing shell to zsh..."
chsh -s $(which zsh) || echo "› Could not change shell (requires sudo or already default)"
echo "› Done!"
